# Copy to .env and fill in. `.env` is gitignored — never commit real secrets.
#
# When using docker-compose.yml, the only value you MUST set for the app
# containers is your OpenAI key; REDIS_URL / MINIO_ENDPOINT are overridden by
# compose to point at the local `redis` and `minio` services.

# ─── LLM (required) ──────────────────────────────────────────────────────────
# OPENAI_API_KEY (or CHATGPT_API_KEY) is required by the PageIndex library.
OPENAI_API_KEY=sk-your-openai-key-here
# CHATGPT_API_KEY=sk-...                       # alias; used if OPENAI_API_KEY unset
# LLM_PROVIDER=auto                            # auto|openai|compatible|azure (default auto)
# OPENAI_BASE_URL=https://api.openai.com/v1    # OpenAI API endpoint or OpenAI-compatible endpoint (vLLM/Together/Groq/OpenRouter/local)
# AZURE_API_VERSION=2024-08-01-preview         # only when using Azure (e.g., https://myresource.openai.azure.com/)

# Model selection. Defaults work with plain OpenAI; set PAGEINDEX_MODEL=azure/<deployment> for Azure ingestion.
# PAGEINDEX_MODEL=gpt-4o-2024-11-20
# PAGEINDEX_FILTER_MODEL=gpt-4o-mini
# PAGEINDEX_SEARCH_MODEL=gpt-4o-mini
# PAGEINDEX_SEARCH_CONCURRENCY=3

# ─── Langfuse tracing (optional, LLM-02) ─────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...                 # project public key; tracing activates ONLY when both keys set (unset = disabled, zero overhead)
LANGFUSE_SECRET_KEY=sk-lf-...                 # project secret key
LANGFUSE_HOST=https://cloud.langfuse.com      # EU region (default); US = https://us.cloud.langfuse.com
LANGFUSE_TRACE_CONTENT=false                  # false = mask prompt/completion bodies before export (usage+cost still recorded); true captures full content. WARNING: true exports document text to Langfuse Cloud — inappropriate for PII corpora

# ─── Auth ────────────────────────────────────────────────────────────────────
UPLOAD_API_KEY=dev-api-key       # required by POST /upload/files (X-API-Key header)
MCP_BEARER_TOKEN=dev-api-key     # Authorization: Bearer <token> on /mcp; empty = auth off

# ─── Redis ───────────────────────────────────────────────────────────────────
# For host-run app against the compose Redis:  redis://localhost:6379/1
# Inside compose this is overridden to redis://redis:6379/1.
REDIS_URL=redis://localhost:6379/1
CACHE_TTL=300

# ─── MinIO ───────────────────────────────────────────────────────────────────
# For host-run app against the compose MinIO:  localhost:9000
# Inside compose this is overridden to minio:9000.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pageindex
MINIO_SECURE=false

# ─── OCR / tessdata (Fix-3 garble escalation, Fix-5 language detect) ──────────
# OCR is local Tesseract only (no LLM egress — PII-safe, HR3). The garble-retry
# path auto-detects language (filename + text sample) so Arabic gazettes get 'ara'.
# DOCLING_DO_OCR=0                  # 1 = OCR every PDF page; default 0 (only the garble retry / images OCR)
# DOCLING_OCR_LANG=deu,eng         # static fallback lang list when auto-detect yields nothing
# OCR_ESCALATION=1                  # 1 (default) = one force_full_page_ocr retry when a PDF garbles
# TESSDATA_ALLOW_DOWNLOAD=0        # 1 = fetch missing <lang>.traineddata at runtime; 0 (default) = pre-baked only
# TESSDATA_PREFIX=                  # dir holding <lang>.traineddata. Empty = trust the system tesseract
#                                   # install (e.g. brew's /opt/homebrew/share/tessdata, which has ara).
#                                   # For egress-limited workers, PRE-BAKE first then point here:
#                                   #   scripts/prebake_tessdata.sh        # bakes ara,eng,deu,osd into .tessdata/
#                                   #   TESSDATA_PREFIX=/app/.tessdata
#                                   # NOTE: when TESSDATA_PREFIX is set, ALL needed langs must be present there
#                                   # (a missing lang is dropped, not fetched) — bake eng/deu too, not just ara.

# ─── PDF conversion & flat-doc routing ────────────────────────────────────────
# PDF_CONVERTER=docling             # docling (default, MIT-clean) | pymupdf4llm (AGPL-3.0, faster)
# DOCLING_ARTIFACTS_PATH=           # dir of pre-downloaded Docling model weights (offline/egress-limited use)
# DOCLING_NUM_THREADS=1             # Docling intra-op thread cap; raise only where the node has RAM headroom
# FLAT_DOC_ROUTING=true             # true (default) = route depth<2/node_count<3 docs to the flat success path

# ─── Memory admission (worker backpressure) ───────────────────────────────────
# MEM_ADMISSION_FLOOR_BYTES=2300000000  # min free RAM required before starting a job (default ~2.3GB)
# MEM_ADMISSION_MAX_WAIT_S=120          # max seconds to wait for headroom before proceeding anyway
# MEM_ADMISSION_POLL_S=3                # polling interval while waiting for headroom

# ─── Observability ─────────────────────────────────────────────────────────────
# ARQ_QUEUE_DEPTH_SCRAPE_INTERVAL_S=5   # arq queue-depth Prometheus scrape interval

# ─── Server ──────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8201
WEB_CONCURRENCY=1                # keep at 1 — MCP sessions are in-memory per worker
